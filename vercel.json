{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/auth/login", "dest": "api/index.py" },
    { "src": "/auth/signup", "dest": "api/index.py" },
    { "src": "/bookings", "dest": "api/index.py" },
    { "src": "/bookings/(.*)", "dest": "api/index.py" },
    { "src": "/users/(.*)", "dest": "api/index.py" },
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}